###############################################################################
# OpenVPN client config for Raspberry Pi (native OpenVPN server)
# Re-generated to match the new server PKI. Everything is identical to your
# original SoftEther-generated file EXCEPT the <ca> block (new CA) and proto.
###############################################################################

dev tun
proto udp
remote 59.25.16.151 1703

;http-proxy-retry
;http-proxy [proxy server] [proxy port]

cipher AES-128-CBC
data-ciphers AES-128-CBC
auth SHA1

resolv-retry infinite
nobind
persist-key
persist-tun
client
verb 3
keepalive 5 60
reneg-sec 0
hand-window 120
tun-mtu 1400
mssfix 1300

# Username / password authentication (no client certificate).
auth-user-pass

# CA certificate of the destination VPN Server (NEW - generated on the Pi).
