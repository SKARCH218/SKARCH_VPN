#!/usr/sbin/nft -f
# NAT (masquerade) so VPN clients reach the LAN / internet through eth0.
# Loaded/unloaded by openvpn-nat.service. Self-contained table so it does
# not clash with any other firewall rules you may add later.
table inet openvpn_nat
delete table inet openvpn_nat
table inet openvpn_nat {
    chain postrouting {
        type nat hook postrouting priority srcnat; policy accept;
        ip saddr 10.8.1.0/24 oifname "eth0" masquerade
        ip saddr 10.8.2.0/24 oifname "eth0" masquerade
    }
    chain forward {
        type filter hook forward priority filter; policy accept;
        ip saddr 10.8.1.0/24 accept
        ip saddr 10.8.2.0/24 accept
        ip daddr 10.8.1.0/24 ct state established,related accept
        ip daddr 10.8.2.0/24 ct state established,related accept
    }
}
